# ============================================================
# NomadNotes 后端环境变量配置
# 复制此文件为 .env 并根据实际环境修改
# 注意：.env 文件已在 .gitignore 中排除，请勿提交到版本库
# ============================================================

# 服务端口
PORT=3434

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=nomadnotes

# JWT 密钥（生产环境务必修改为随机字符串）
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production

# Token 过期时间
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS 允许的前端来源（多个来源用逗号分隔）
# 开发环境：Vite 默认端口 5173
CORS_ORIGIN=http://localhost:5173

# 文件上传
# 上传文件存储目录（相对于 server 目录）
UPLOAD_DIR=uploads
# 单文件大小限制
MAX_FILE_SIZE_MB=10

# 日志级别：error / warn / info / debug
LOG_LEVEL=info